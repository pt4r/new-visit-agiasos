---
interface Props {
  title: string;
  backgroundImage?: string;
  backgroundClass?: string;
}

const { title, backgroundImage, backgroundClass } = Astro.props;
---

<section id="int-hero" class:list={["int-hero", backgroundClass]}>
  <h1 id="home-h">{title}</h1>
  {backgroundImage && (
    <picture>
      <img
        aria-hidden="true"
        decoding="async"
        src={backgroundImage}
        alt=""
        loading="eager"
        width="2500"
        height="1667"
      />
    </picture>
  )}
</section>

<style lang="less">
  .int-hero {
    width: 100%;
    height: 50svh;
    min-height: 18.75rem;
    display: flex;
    justify-content: center;
    align-items: center;
    position: relative;
    z-index: 1;
    overflow: hidden;

    picture {
      width: 100%;
      height: 100%;
      display: block;
      position: absolute;
      top: 0;
      left: 0;
      z-index: -1;

      &::before {
        content: "";
        width: 100%;
        height: 100%;
        background: #000;
        opacity: 0.7;
        display: block;
        position: absolute;
        top: 0;
        left: 0;
        z-index: 1;
      }

      img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        position: absolute;
        top: 0;
        left: 0;
      }
    }

    h1 {
      font-size: clamp(2.4375rem, 6.4vw, 3.8125rem);
      color: #fff;
      text-align: center;
      width: 96%;
      max-width: 31.25rem;
      margin: 0 auto;
      position: relative;
      z-index: 1;
    }
  }

  .bg-color-history {
    background-color: var(--history, #142a51);
    h1 {
      color: #fff;
    }
  }
</style>
