---
import { getImage } from "astro:assets";

interface Props {
  title: string;
  backgroundImage?: string | ImageMetadata;
  backgroundClass?: string;
}

const { title, backgroundImage, backgroundClass } = Astro.props;

let imgSrc = "";
let imgWidth = 1600;
let imgHeight = 900;

if (backgroundImage) {
  if (typeof backgroundImage === "string") {
    imgSrc = backgroundImage;
  } else {
    const optimized = await getImage({ src: backgroundImage, width: 1600, format: "webp" });
    imgSrc = optimized.src;
    imgWidth = optimized.attributes.width as number ?? 1600;
    imgHeight = optimized.attributes.height as number ?? 900;
  }
}
---

<section id="int-hero" class:list={["int-hero", backgroundClass]}>
  <h1 id="home-h">{title}</h1>
  {imgSrc && (
    <picture>
      <img
        aria-hidden="true"
        decoding="async"
        src={imgSrc}
        alt=""
        loading="eager"
        width={imgWidth}
        height={imgHeight}
      />
    </picture>
  )}
</section>

<style lang="less">
  .int-hero {
    width: 100%;
    height: 50svh;
    min-height: 18.75rem;
    display: flex;
    justify-content: center;
    align-items: center;
    position: relative;
    z-index: 1;
    overflow: hidden;

    picture {
      width: 100%;
      height: 100%;
      display: block;
      position: absolute;
      top: 0;
      left: 0;
      z-index: -1;

      &::before {
        content: "";
        width: 100%;
        height: 100%;
        background: #000;
        opacity: 0.7;
        display: block;
        position: absolute;
        top: 0;
        left: 0;
        z-index: 1;
      }

      img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        position: absolute;
        top: 0;
        left: 0;
      }
    }

    h1 {
      font-size: clamp(2.4375rem, 6.4vw, 3.8125rem);
      color: #fff;
      text-align: center;
      width: 96%;
      max-width: 31.25rem;
      margin: 0 auto;
      position: relative;
      z-index: 1;
    }
  }

  .bg-color-history {
    background-color: var(--history, #142a51);
    h1 {
      color: #fff;
    }
  }
</style>
