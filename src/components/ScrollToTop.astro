<button type="button" aria-label="Scroll to top" id="scrolltop-btn" class="scrolltop-btn">
    <svg viewBox="0 0 48 48" width="48" height="48" xmlns="http://www.w3.org/2000/svg">
        <path id="scrolltop-bg" d="M0 0h48v48h-48z"></path>
        <path id="scrolltop-arrow" d="M14.83 30.83l9.17-9.17 9.17 9.17 2.83-2.83-12-12-12 12z"></path>
    </svg>
</button>

<script>
document.addEventListener('astro:page-load', () => {
    const btn = document.getElementById('scrolltop-btn');
    if (!btn) return;

    btn.addEventListener('click', () => {
        window.scrollTo({ top: 0, behavior: 'smooth' });
    });

    const onScroll = () => {
        if (window.scrollY > 300) {
            btn.classList.add('is-visible');
        } else {
            btn.classList.remove('is-visible');
        }
    };

    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
});
</script>

<style lang="css">
.scrolltop-btn {
  position: fixed;
  bottom: 2rem;
  right: 2rem;
  width: 3rem;
  height: 3rem;
  z-index: 99999;
  border: none;
  background: none;
  padding: 0;
  cursor: pointer;
  opacity: 0;
  visibility: hidden;
  transform: translateY(1rem);
  transition: opacity 0.3s, visibility 0.3s, transform 0.3s;
}

.scrolltop-btn.is-visible {
  opacity: 1;
  visibility: visible;
  transform: translateY(0);
}

.scrolltop-btn #scrolltop-bg {
  fill: var(--language, #5777bb);
  transition: fill 0.2s;
}

.scrolltop-btn #scrolltop-arrow {
  fill: white;
  transform: scale(0.66);
  transform-origin: center;
  transition: fill 0.2s;
}

.scrolltop-btn:hover #scrolltop-bg {
  fill: var(--primary, #c44609);
}

.scrolltop-btn:hover #scrolltop-arrow {
  fill: white;
}

.scrolltop-btn svg {
  display: block;
  border-radius: 50%;
  width: 100%;
  height: 100%;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.15);
  border-radius: 50%;
}

.scrolltop-btn:focus-visible {
  outline: 2px solid var(--primary, #c44609);
  outline-offset: 2px;
}

@media print {
  .scrolltop-btn {
    display: none !important;
  }
}
</style>
