---
interface Props {
  lat: string;
  lng: string;
  title?: string;
  zoom?: number;
}

const { lat, lng, title = "Location", zoom = 16 } = Astro.props;
const mapUrl = `https://www.google.com/maps/embed?pb=!1m14!1m12!1m3!1d3000!2d${lng}!3d${lat}!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f${zoom}!5e0!3m2!1sen!2sgr!4v1`;
---

<div class="map-wrapper">
  <iframe
    src={mapUrl}
    width="100%"
    height="450"
    style="border:0;"
    allowfullscreen
    loading="lazy"
    referrerpolicy="no-referrer-when-downgrade"
    title={title}
  ></iframe>
</div>

<style lang="less">
  .map-wrapper {
    width: 100%;
    border-radius: 0.5rem;
    overflow: hidden;
    margin: 2rem 0;

    iframe {
      display: block;
      width: 100%;
      min-height: 28.125rem;
    }
  }
</style>
