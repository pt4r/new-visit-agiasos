---
import BaseLayout from "@layouts/BaseLayout.astro";
import CTA from "@components/CTA.astro";
import { getLocalePath, getLocale, t } from "i18n:astro";
import { getOptimizedImage, getMobileOptimizedImage, getCollectionWithFallback } from "@utils/utils";
import ChevronRight from "@lucide/astro/icons/chevron-right";
import MapPinned from "@lucide/astro/icons/map-pinned";
import Map from "@lucide/astro/icons/map";
import Tent from "@lucide/astro/icons/tent";
import HeartHandshake from "@lucide/astro/icons/heart-handshake";

// Optimize our landing image and pass it as props to the BaseLayout (for preloading) and Hero (for rendering)
import landingImage from "@assets/images/hero-cherries.webp"; // <-- THE PATH TO THE ASSET YOU WANT TO PRELOAD - The asset must live in src
import mobileLandingImage from "@assets/images/hero-cherries-m.webp"; // <-- THE PATH TO THE ASSET YOU WANT TO PRELOAD - The asset must live in src
// Thematic category images
import historyImg from "@assets/images/va-logos/History-VA-logo.webp";
import religionImg from "@assets/images/va-logos/Religion-VA-logo.webp";
import foodImg from "@assets/images/va-logos/Food-VA-logo.webp";
import natureImg from "@assets/images/va-logos/Nature-VA-logo.webp";
import artImg from "@assets/images/va-logos/Art-VA-logo.webp";
import languageImg from "@assets/images/va-logos/Language-VA-logo.webp";

import AgiasosFaces from "@assets/images/visit-agiasos-faces.webp";
import KidsPlaying from "@assets/images/kids-playing-in-visitagiasos.webp";

import agiasosImg from "@assets/images/agiasos-uncompr.webp";
import christmasImg from "@assets/images/va-christmas.webp";

const optimizedLandingImage = await getOptimizedImage(landingImage);
const optimizedMobileLandingImage = await getOptimizedImage(mobileLandingImage);

const [historyOpt, historyMob] = await Promise.all([getOptimizedImage(historyImg), getMobileOptimizedImage(historyImg, 413, 240)]);
const [religionOpt, religionMob] = await Promise.all([getOptimizedImage(religionImg), getMobileOptimizedImage(religionImg, 413, 240)]);
const [foodOpt, foodMob] = await Promise.all([getOptimizedImage(foodImg), getMobileOptimizedImage(foodImg, 413, 240)]);
const [natureOpt, natureMob] = await Promise.all([getOptimizedImage(natureImg), getMobileOptimizedImage(natureImg, 413, 240)]);
const [artOpt, artMob] = await Promise.all([getOptimizedImage(artImg), getMobileOptimizedImage(artImg, 413, 240)]);
const [languageOpt, languageMob] = await Promise.all([getOptimizedImage(languageImg), getMobileOptimizedImage(languageImg, 413, 240)]);
const [facesOpt, facesMob] = await Promise.all([getOptimizedImage(AgiasosFaces), getMobileOptimizedImage(AgiasosFaces, 400, 563)]);
const [kidsOpt, kidsMob] = await Promise.all([getOptimizedImage(KidsPlaying), getMobileOptimizedImage(KidsPlaying, 400, 563)]);
const [agiasosOpt, agiasosMob] = await Promise.all([getOptimizedImage(agiasosImg, { loading: "lazy" }), getMobileOptimizedImage(agiasosImg, 400, 560)]);
const [christmasOpt, christmasMob] = await Promise.all([getOptimizedImage(christmasImg, { loading: "lazy" }), getMobileOptimizedImage(christmasImg, 400, 560)]);

const locale = getLocale();
const activities = await getCollectionWithFallback("activities", locale);

export const prerender = true;
---

<BaseLayout title={t("home:layout.title")} description={t("home:layout.description")} preloadedImage={optimizedMobileLandingImage}>
	<!-- ============================================ -->
	<!--                    Hero                      -->
	<!-- ============================================ -->
	<section id="hero-home">
		<div class="cs-container">
		<div class="cs-content" data-animate="fade-up">
			<span class="cs-topper">{t("home:hero.topper")}</span>
			<h1 class="cs-title font-bold">{t("home:hero.title")}</h1>
			<div class="cs-button-group">
				<a href="#heritage" class="cs-button-solid cs-hero-button-secondary">{t("home:hero.cta1")}</a>
				<a href="#sbs" class="cs-button-solid cs-hero-button-primary">{t("home:hero.cta2")}</a>
			</div>
		</div>
			<ul class="cs-card-group">
				<li class="cs-item">
					<MapPinned class="cs-icon" height="48" width="48" stroke-width="1.3" />
					<h2 class="cs-h3">{t("home:hero.pills.pill1.heading")}</h2>
					<p class="cs-item-text">{t("home:hero.pills.pill1.text")}</p>
				</li>
				<li class="cs-item">
					<Map class="cs-icon" height="48" width="48" stroke-width="1.3" />
					<h2 class="cs-h3">{t("home:hero.pills.pill2.heading")}</h2>
					<p class="cs-item-text" set:html={t("home:hero.pills.pill2.text")} />
				</li>
				<li class="cs-item">
					<Tent class="cs-icon" height="48" width="48" stroke-width="1.3" />
					<h2 class="cs-h3">{t("home:hero.pills.pill3.heading")}</h2>
					<p class="cs-item-text">{t("home:hero.pills.pill3.text")}</p>
				</li>
				<li class="cs-item">
					<HeartHandshake class="cs-icon" height="48" width="48" stroke-width="1.3" />
					<h2 class="cs-h3">{t("home:hero.pills.pill4.heading")}</h2>
					<p class="cs-item-text">{t("home:hero.pills.pill4.text")}</p>
				</li>
			</ul>
		</div>

		<!-- Background Image -->
		<picture class="cs-background" style={`--hero-image: url(${optimizedLandingImage.src})`}>
			<source media="(max-width: 600px)" srcset={optimizedMobileLandingImage.src} />
			<source media="(min-width: 601px)" srcset={optimizedLandingImage.src} />
			<img aria-hidden="true" src={optimizedLandingImage.src} width={optimizedLandingImage.attributes.width} height={optimizedLandingImage.attributes.height} loading="eager" alt="" />
		</picture>
	</section>

	<!-- ============================================ -->
	<!--                Activities                    -->
	<!-- ============================================ -->
	{activities.length > 0 && (
	<section id="activities-section">
		<div class="activities-container">
			<div class="activities-header">
				<div>
					<span class="cs-topper">{t("home:activities.topper")}</span>
					<h2 class="cs-title">{t("home:activities.title")}</h2>
				</div>
				<a href={getLocalePath("/activities")} class="cs-button-solid activities-cta">
					{t("home:activities.cta")}
				</a>
			</div>

			<div class="activities-carousel-wrapper">
				<button class="carousel-btn carousel-btn--prev" aria-label="Previous" type="button">
					<ChevronRight class="carousel-chevron carousel-chevron--flipped" width="24" height="24" />
				</button>

				<div class="activities-carousel">
					{activities.map((activity) => {
						const slug = activity.id.replace(/^(en|el)\//, "");
						return (
							<article class="activity-card card-base" data-href={getLocalePath(`/activities/${slug}`)}>
								{activity.data.image && (
									<div class="activity-card__image">
										<img
											src={activity.data.image}
											alt={activity.data.imageAlt || activity.data.title}
											loading="lazy"
											decoding="async"
											width="320"
											height="200"
										/>
									</div>
								)}
								<div class="activity-card__body">
									<h3 class="activity-card__title">{activity.data.title}</h3>
									{activity.data.description && (
										<p class="activity-card__desc">{activity.data.description}</p>
									)}
									<a href={getLocalePath(`/activities/${slug}`)} class="activity-card__link">
										{t("home:activities.readMore")} <ChevronRight width="16" height="16" />
									</a>
								</div>
							</article>
						);
					})}
				</div>

				<button class="carousel-btn carousel-btn--next" aria-label="Next" type="button">
					<ChevronRight class="carousel-chevron" width="24" height="24" />
				</button>
			</div>
		</div>
	</section>
	)}

	<!-- ============================================ -->
	<!--              Thematic categories             -->
	<!-- ============================================ -->

	<section id="heritage">
		<div class="cs-container">
			<div class="cs-content" data-animate="fade-up">
				<span class="cs-topper">{t("home:heritage.topper")}</span>
				<h2 class="cs-title">{t("home:heritage.title")}</h2>
				<p class="cs-text" set:html={t("home:heritage.text")} />
				<h4>{t("home:heritage.subtitle")}</h4>
			</div>
			<ul class="cs-card-group" data-animate="fade-up" data-stagger>
			<li class="cs-item bg-color-history">
					<a href={getLocalePath("/history-of-agiasos")} class="cs-link">
						<picture class="cs-picture">
							<source media="(max-width: 600px)" srcset={historyMob.src} />
							<source media="(min-width: 601px)" srcset={historyOpt.src} />
							<img loading="lazy" decoding="async" src={historyOpt.src} alt="category history" width="413" height="240" aria-hidden="true" />
						</picture>
						<h3 class="cs-h3">{t("home:heritage.history")}</h3>
					</a>
				</li>
				<li class="cs-item bg-color-religion">
					<a href={getLocalePath("/religion-in-agiasos")} class="cs-link">
						<picture class="cs-picture">
							<source media="(max-width: 600px)" srcset={religionMob.src} />
							<source media="(min-width: 601px)" srcset={religionOpt.src} />
							<img loading="lazy" decoding="async" src={religionOpt.src} alt="religion history" width="413" height="240" aria-hidden="true" />
						</picture>
						<h3 class="cs-h3">{t("home:heritage.religion")}</h3>
					</a>
				</li>
				<li class="cs-item bg-color-food">
					<a href={getLocalePath("/food-in-agiasos")} class="cs-link">
						<picture class="cs-picture">
							<source media="(max-width: 600px)" srcset={foodMob.src} />
							<source media="(min-width: 601px)" srcset={foodOpt.src} />
							<img loading="lazy" decoding="async" src={foodOpt.src} alt="food history" width="413" height="240" aria-hidden="true" />
						</picture>
						<h3 class="cs-h3">{t("home:heritage.food")}</h3>
					</a>
				</li>
				<li class="cs-item bg-color-nature">
					<a href={getLocalePath("/nature-of-agiasos")} class="cs-link">
						<picture class="cs-picture">
							<source media="(max-width: 600px)" srcset={natureMob.src} />
							<source media="(min-width: 601px)" srcset={natureOpt.src} />
							<img loading="lazy" decoding="async" src={natureOpt.src} alt="nature history" width="413" height="240" aria-hidden="true" />
						</picture>
						<h3 class="cs-h3">{t("home:heritage.nature")}</h3>
					</a>
				</li>
				<li class="cs-item bg-color-art">
					<a href={getLocalePath("/art-of-agiasos")} class="cs-link">
						<picture class="cs-picture">
							<source media="(max-width: 600px)" srcset={artMob.src} />
							<source media="(min-width: 601px)" srcset={artOpt.src} />
							<img loading="lazy" decoding="async" src={artOpt.src} alt="art history" width="413" height="240" aria-hidden="true" />
						</picture>
						<h3 class="cs-h3">{t("home:heritage.art")}</h3>
					</a>
				</li>
				<li class="cs-item bg-color-language">
					<a href={getLocalePath("/language-of-agiasos")} class="cs-link">
						<picture class="cs-picture">
							<source media="(max-width: 600px)" srcset={languageMob.src} />
							<source media="(min-width: 601px)" srcset={languageOpt.src} />
							<img loading="lazy" decoding="async" src={languageOpt.src} alt="language history" width="413" height="240" aria-hidden="true" />
						</picture>
						<h3 class="cs-h3">{t("home:heritage.language")}</h3>
					</a>
				</li>
			</ul>
		</div>
	</section>
	<!-- ============================================ -->
	<!--                 Who we are                 -->
	<!-- ============================================ -->

	<section id="sbs">
		<div class="cs-container">
			<!-- Left Image Section -->
			<div class="cs-left" data-animate="fade-right">
				<picture class="cs-picture cs-picture1">
					<source media="(max-width: 600px)" srcset={facesMob.src} />
					<source media="(min-width: 601px)" srcset={facesOpt.src} />
					<img
						class="object-[0%_80%]"
						aria-hidden="true"
						decoding="async"
						src={facesOpt.src}
						alt="visit agiasos faces"
						loading="lazy"
						width="400"
						height="563"
					/>
				</picture>
				<picture class="cs-picture cs-picture2">
					<source media="(max-width: 600px)" srcset={kidsMob.src} />
					<source media="(min-width: 601px)" srcset={kidsOpt.src} />
					<img aria-hidden="true" decoding="async" src={kidsOpt.src} alt="kids playing in visitagiasos" loading="lazy" width="400" height="563" />
				</picture>
			</div>
			<!-- Right Content Section-->
			<div class="cs-right" data-animate="fade-left">
				<span class="cs-topper">{t("home:whoWeAre.topper")}</span>
				<h2 class="cs-title">{t("home:whoWeAre.title")}</h2>
				<p class="cs-text">{t("home:whoWeAre.text")}</p>
				<a href={getLocalePath("/about")} class="cs-button-solid">{t("home:whoWeAre.cta")}</a>
			</div>
		</div>
	</section>

	<!-- ============================================ -->
	<!--            Discover Agiasos                  -->
	<!-- ============================================ -->

	<section id="sbs-r">
		<div class="cs-container">
			<div class="cs-left" data-animate="fade-left">
				<picture class="cs-picture cs-picture1">
					<source media="(max-width: 600px)" srcset={agiasosMob.src} />
					<source media="(min-width: 601px)" srcset={agiasosOpt.src} />
					<img aria-hidden="true" decoding="async" src={agiasosOpt.src} alt="Agiasos village" loading="lazy" width="400" height="560" />
				</picture>
				<picture class="cs-picture cs-picture2">
					<source media="(max-width: 600px)" srcset={christmasMob.src} />
					<source media="(min-width: 601px)" srcset={christmasOpt.src} />
					<img aria-hidden="true" decoding="async" src={christmasOpt.src} alt="Agiasos events" loading="lazy" width="400" height="560" />
				</picture>
			</div>
			<div class="cs-right" data-animate="fade-right">
				<span class="cs-topper">{t("home:discover.topper")}</span>
				<h2 class="cs-title">{t("home:discover.title")}</h2>
				<p class="cs-text">{t("home:discover.text")}</p>
				<a href={getLocalePath("/agiasos-lesbos")} class="cs-button-solid">{t("home:discover.cta")}</a>
			</div>
		</div>
	</section>

	<!-- ============================================ -->
	<!--                   Gallery                    -->
	<!-- ============================================ -->

	<section id="gallery">
		<div class="cs-container" data-animate="fade-up">
			<span class="cs-topper">{t("home:portfolio.topper")}</span>
			<h2 class="cs-title">
				{t("home:portfolio.title")}
			</h2>
			<div class="cs-image-group">
				<!-- Row 1-->
				<div class="cs-row cs-row-1">
					<!-- To add more images, copy and paste this row's picture tags here in order from cs-picture-1 to cs-picture-3 and they will maintain the same layout-->
					<picture class="cs-picture cs-picture1">
						<source media="(max-width: 600px)" srcset="/assets/images/portfolio/port1-m.webp" />
						<source media="(min-width: 601px)" srcset="/assets/images/portfolio/port1.webp" />
						<img aria-hidden="true" decoding="async" src="/assets/images/portfolio/port1.webp" alt="new hallway" loading="lazy" width="400" height="560" />
					</picture>
					<picture class="cs-picture cs-picture2">
						<source media="(max-width: 600px)" srcset="/assets/images/portfolio/port4-m.webp" />
						<source media="(min-width: 601px)" srcset="/assets/images/portfolio/port4.webp" />
						<img aria-hidden="true" decoding="async" src="/assets/images/portfolio/port4.webp" alt="new home construction" loading="lazy" width="400" height="560" />
					</picture>
					<picture class="cs-picture cs-picture3">
						<source media="(max-width: 600px)" srcset="/assets/images/portfolio/port7-m.webp" />
						<source media="(min-width: 601px)" srcset="/assets/images/portfolio/port7.webp" />
						<img aria-hidden="true" decoding="async" src="/assets/images/portfolio/port7.webp" alt="building a new wall" loading="lazy" width="400" height="560" />
					</picture>
				</div>
				<!-- Row 2 -->
				<div class="cs-row cs-row-2">
					<!-- To add more images, copy and paste this row's picture tags here in order from cs-picture-1 to cs-picture-3 and they will maintain the same layout-->
					<picture class="cs-picture cs-picture1">
						<source media="(max-width: 600px)" srcset="/assets/images/portfolio/port2-m.webp" />
						<source media="(min-width: 601px)" srcset="/assets/images/portfolio/port2.webp" />
						<img aria-hidden="true" decoding="async" src="/assets/images/portfolio/port2.webp" alt="new kitchen" loading="lazy" width="400" height="560" />
					</picture>
					<picture class="cs-picture cs-picture2">
						<source media="(max-width: 600px)" srcset="/assets/images/portfolio/port5-m.webp" />
						<source media="(min-width: 601px)" srcset="/assets/images/portfolio/port5.webp" />
						<img aria-hidden="true" decoding="async" src="/assets/images/portfolio/port5.webp" alt="apartment addition" loading="lazy" width="400" height="560" />
					</picture>
					<picture class="cs-picture cs-picture3">
						<source media="(max-width: 600px)" srcset="/assets/images/portfolio/port8-m.webp" />
						<source media="(min-width: 601px)" srcset="/assets/images/portfolio/port8.webp" />
						<img aria-hidden="true" decoding="async" src="/assets/images/portfolio/port8.webp" alt="kew kitchen cabinets" loading="lazy" width="400" height="560" />
					</picture>
				</div>
				<!-- Row 3 -->
				<div class="cs-row cs-row-3">
					<!-- To add more images, copy and paste this row's picture tags here in order from cs-picture-1 to cs-picture-3 and they will maintain the same layout-->
					<picture class="cs-picture cs-picture1">
						<source media="(max-width: 600px)" srcset="/assets/images/portfolio/port3-m.webp" />
						<source media="(min-width: 601px)" srcset="/assets/images/portfolio/port3.webp" />
						<img aria-hidden="true" decoding="async" src="/assets/images/portfolio/port3.webp" alt="new kitchen" loading="lazy" width="400" height="560" />
					</picture>
					<picture class="cs-picture cs-picture2">
						<source media="(max-width: 600px)" srcset="/assets/images/portfolio/port6-m.webp" />
						<source media="(min-width: 601px)" srcset="/assets/images/portfolio/port6.webp" />
						<img aria-hidden="true" decoding="async" src="/assets/images/portfolio/port6.webp" alt="apartment addition" loading="lazy" width="400" height="560" />
					</picture>
					<picture class="cs-picture cs-picture3">
						<source media="(max-width: 600px)" srcset="/assets/images/portfolio/port9-m.webp" />
						<source media="(min-width: 601px)" srcset="/assets/images/portfolio/port9.webp" />
						<img aria-hidden="true" decoding="async" src="/assets/images/portfolio/port9.webp" alt="kew kitchen cabinets" loading="lazy" width="400" height="560" />
					</picture>
				</div>
			</div>
		</div>
	</section>

	<CTA />
</BaseLayout>

<style lang="less">
	/* STYLES FOR ABOVE THE FOLD */

	/*-- -------------------------- -->
<---        Activities          -->
<--- -------------------------- -*/

	#activities-section {
		padding: var(--sectionPadding);
		background: var(--sectionBgColorBright);
	}

	.activities-container {
		width: 92%;
		max-width: 80rem;
		margin: auto;
	}

	.activities-header {
		display: flex;
		justify-content: space-between;
		align-items: flex-start;
		flex-wrap: wrap;
		gap: 1rem;
		margin-bottom: 2rem;

		.cs-title {
			margin-bottom: 0;
		}
	}

	.activities-cta {
		flex-shrink: 0;
		align-self: center;
	}

	.activities-carousel-wrapper {
		position: relative;
	}

	.activities-carousel {
		display: flex;
		justify-content: center;
		gap: 1.25rem;
		overflow-x: auto;
		scroll-behavior: smooth;
		scroll-snap-type: x mandatory;
		-webkit-overflow-scrolling: touch;
		padding-bottom: 0.5rem;

		scrollbar-width: none;
		&::-webkit-scrollbar {
			display: none;
		}
	}

	.activity-card {
		flex: 0 0 280px;
		scroll-snap-align: start;
		display: flex;
		flex-direction: column;
		cursor: pointer;

		&__image {
			width: 100%;
			aspect-ratio: 16 / 10;
			overflow: hidden;

			img {
				width: 100%;
				height: 100%;
				object-fit: cover;
				transition: transform 0.3s;
			}
		}

		&:hover &__image img {
			transform: scale(1.05);
		}

		&__body {
			padding: 1rem 1.25rem 1.25rem;
			display: flex;
			flex-direction: column;
			flex: 1;
		}

		&__title {
			font-size: 1.1rem;
			font-weight: 700;
			margin: 0 0 0.25rem;
			color: var(--headerColor);
		}

		&__desc {
			font-size: 0.875rem;
			color: var(--bodyTextColor);
			line-height: 1.5;
			margin: 0 0 auto;
			display: -webkit-box;
			-webkit-line-clamp: 3;
			-webkit-box-orient: vertical;
			overflow: hidden;
		}

		&__link {
			display: inline-flex;
			align-items: center;
			gap: 0.25rem;
			margin-top: 1rem;
			font-weight: 700;
			font-size: 0.9rem;
			color: var(--primary);
			text-decoration: none;

			&:hover {
				text-decoration: underline;
			}
		}
	}

	.carousel-btn {
		display: none;
	}

	@media only screen and (min-width: 64rem) {
		.activity-card {
			flex: 0 0 calc(25% - 0.9375rem);
		}

		.carousel-btn {
			display: flex;
			position: absolute;
			top: calc(50% - 3rem);
			z-index: 2;
			width: 2.5rem;
			height: 2.5rem;
			border-radius: 50%;
			border: 1px solid #ddd;
			background: #fff;
			align-items: center;
			justify-content: center;
			cursor: pointer;
			box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
			transition: box-shadow 0.2s, transform 0.2s;

			&:hover {
				box-shadow: 0 4px 16px rgba(0, 0, 0, 0.15);
				transform: scale(1.05);
			}

			&--prev {
				left: -1.25rem;
			}
			&--next {
				right: -1.25rem;
			}
		}

		.carousel-chevron {
