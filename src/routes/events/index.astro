---
export const prerender = true;
import BaseLayout from "@layouts/BaseLayout.astro";
import HeroBanner from "@components/HeroBanner.astro";
import ContentListing from "@components/ContentListing.astro";
import { getLocale, t } from "i18n:astro";
import { getOptimizedImage, getCollectionWithFallback } from "@utils/utils";
import landingImage from "@assets/images/landing.webp";

const optimizedImage = await getOptimizedImage(landingImage);
const locale = getLocale();
const allEvents = await getCollectionWithFallback("events", locale);

const items = allEvents
  .sort((a, b) => new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf())
  .map((e) => ({
    slug: e.id.replace(/^(en|el)\//, ""),
    title: e.data.title,
    description: e.data.description,
    image: e.data.image,
    imageAlt: e.data.imageAlt,
    date: e.data.date.toISOString(),
    tags: e.data.tags,
  }));
---

<BaseLayout
  title={t("events")}
  description={t("events:description")}
  preloadedImage={optimizedImage}
>
  <HeroBanner title={t("events")} backgroundImage="/assets/images/hero-cherries.webp" />

  <section class="events-section">
    <div class="cs-container">
      <ContentListing items={items} basePath="/events/" locale={locale} />
    </div>
  </section>
</BaseLayout>

<style lang="less">
  .events-section {
    padding: var(--sectionPadding);
  }

  .cs-container {
    max-width: 80rem;
    margin: 0 auto;
    width: 92%;
  }
</style>
