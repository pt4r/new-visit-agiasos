---
export const prerender = true;
import BaseLayout from "@layouts/BaseLayout.astro";
import HeroBanner from "@components/HeroBanner.astro";
import { getLocale, getLocalePath, t } from "i18n:astro";
import { getCollectionWithFallback, resolveImagePath } from "@utils/utils";

const locale = getLocale();

const allProducts = await getCollectionWithFallback("products", locale);
const products = allProducts
  .filter((p) => p.data.available !== false)
  .map((p) => ({
    slug: p.id.replace(/^(en|el)\//, ""),
    title: p.data.title,
    description: p.data.description,
    price: p.data.price,
    compareAtPrice: p.data.compareAtPrice,
    images: (p.data.images || []).map(resolveImagePath),
    image: p.data.image ? resolveImagePath(p.data.image) : undefined,
    available: p.data.available,
  }));
---

<BaseLayout
  title={t("souvenirs")}
  description={t("shop:description")}
>
  <HeroBanner title={t("souvenirs")} backgroundImage="/assets/images/hero-cherries.webp" />

  <section class="shop-section">
    <div class="cs-container">
      <div class="cs-content" data-animate="fade-up">
        <span class="cs-topper">{t("shop:topper")}</span>
        <h2 class="cs-title">{t("shop:title")}</h2>
        <p class="cs-text">{t("shop:text")}</p>
      </div>

      {products.length === 0 ? (
        <div class="empty-state" data-animate="fade-up">
          <p>{t("shop:emptyState")}</p>
        </div>
      ) : (
        <div class="product-grid" data-animate="fade-up" data-stagger>
          {products.map((product) => (
            <a href={getLocalePath(`/shop/${product.slug}/`)} class="product-card card-base">
              {(product.images?.[0] || product.image) && (
                <div class="product-image">
                  <img
                    src={product.images?.[0] || product.image}
                    alt={product.title}
                    loading="lazy"
                    decoding="async"
                    width="400"
                    height="400"
                  />
                  {product.compareAtPrice && product.compareAtPrice > product.price && (
                    <span class="sale-badge">
                      {Math.round((1 - product.price / product.compareAtPrice) * 100)}% Off
                    </span>
                  )}
                </div>
              )}
              <div class="product-info">
                <h3 class="product-title">{product.title}</h3>
                <div class="product-pricing">
                  <span class="product-price">&euro;{product.price?.toFixed(2)}</span>
                  {product.compareAtPrice && product.compareAtPrice > product.price && (
                    <span class="product-compare-price">&euro;{product.compareAtPrice.toFixed(2)}</span>
                  )}
                </div>
              </div>
            </a>
          ))}
        </div>
      )}
    </div>
  </section>
</BaseLayout>

<style lang="less">
  .shop-section {
    padding: var(--sectionPadding);
  }

  .cs-container {
    max-width: 80rem;
    margin: 0 auto;
    width: 92%;
  }

  .cs-content {
    text-align: center;
    max-width: 40rem;
    margin: 0 auto 3rem;
  }

  .empty-state {
    text-align: center;
    padding: 4rem 1rem;
    color: var(--bodyTextColor);
  }

  .product-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(16rem, 1fr));
    gap: 1.5rem;
  }

  .product-card {
    display: block;
    text-decoration: none;
  }

  .product-image {
    position: relative;

    img {
      width: 100%;
      aspect-ratio: 1;
      object-fit: cover;
      display: block;
    }
  }

  .sale-badge {
    position: absolute;
    top: 0.75rem;
    right: 0.75rem;
    background: var(--primary, #c44609);
    color: #fff;
    font-size: 0.75rem;
    font-weight: 700;
    padding: 0.25rem 0.625rem;
    border-radius: 1rem;
  }

  .product-info {
    padding: 1rem;
  }

  .product-title {
    font-size: 1rem;
    color: var(--headerColor);
    margin: 0 0 0.5rem;
  }

  .product-pricing {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .product-price {
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--primary, #c44609);
  }

  .product-compare-price {
    font-size: 0.875rem;
    color: var(--bodyTextColor);
    text-decoration: line-through;
    opacity: 0.6;
  }
</style>
