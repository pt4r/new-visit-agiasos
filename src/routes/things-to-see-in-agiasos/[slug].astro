---
export const prerender = true;
import BaseLayout from "@layouts/BaseLayout.astro";
import HeroBanner from "@components/HeroBanner.astro";
import Breadcrumb from "@components/Breadcrumb.astro";
import ImageCarousel from "@components/ImageCarousel.astro";
import GoogleMap from "@components/GoogleMap.astro";
import type { InferGetStaticPropsType } from "astro";
import { getLocalePath, getLocalePlaceholder, setDynamicParams, t } from "i18n:astro";
import { render } from "astro:content";
import { getOptimizedImage, getCollectionWithFallback } from "@utils/utils";
import landingImage from "@assets/images/landing.webp";

const optimizedImage = await getOptimizedImage(landingImage);

export async function getStaticPaths() {
  const locale = getLocalePlaceholder();
  const pois = await getCollectionWithFallback("pois", locale);

  return pois.map((poi) => {
    const slug = poi.id.replace(/^(en|el)\//, "");
    return {
      params: { slug },
      props: {
        poi,
        dynamicParams: [
          { locale: "en", params: { slug } },
          { locale: "el", params: { slug } },
        ],
      },
    };
  });
}

type Props = InferGetStaticPropsType<typeof getStaticPaths>;
const { poi, dynamicParams } = Astro.props;
setDynamicParams(dynamicParams);

const { title, description, excerpt, primaryImage, galleryImages, mapLat, mapLng } = poi.data;
const gallery = galleryImages.map((src: string) => ({ src, alt: title }));
const { Content } = await render(poi);
---

<BaseLayout title={title} description={description} preloadedImage={optimizedImage}>
  {primaryImage ? (
    <HeroBanner title={title} backgroundImage={primaryImage} />
  ) : (
    <HeroBanner title={title} backgroundClass="bg-color-history" />
  )}

  <section class="poi-section">
    <div class="cs-container">
      <Breadcrumb items={[
        { label: t("things-to-see-in-agiasos"), url: "/things-to-see-in-agiasos/" },
        { label: title }
      ]} />

      {excerpt && (
        <div class="excerpt" data-animate="fade-up">
          <p>{excerpt}</p>
        </div>
      )}

      {gallery.length > 0 && (
        <div class="gallery" data-animate="fade-up">
          <ImageCarousel images={gallery} />
        </div>
      )}

      <div class="content" data-animate="fade-up">
        <Content />
      </div>

      {mapLat && mapLng && (
        <GoogleMap lat={mapLat} lng={mapLng} title={title} />
      )}

      <div class="back-link">
        <a href={getLocalePath("/things-to-see-in-agiasos/")} class="cs-button-solid">
          &larr; Back to Points of Interest
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style lang="less">
  .poi-section {
    padding: var(--sectionPadding);
  }

  .cs-container {
    max-width: 50rem;
    margin: 0 auto;
    width: 92%;
  }

  .excerpt {
    text-align: center;
    font-size: 1.125rem;
    color: var(--bodyTextColor);
    margin-bottom: 2rem;
    line-height: 1.6;
  }

  .gallery {
    margin-bottom: 2rem;
  }

  .content {
    line-height: 1.7;
    margin-bottom: 2rem;

    p {
      margin-bottom: 1rem;
    }
  }

  .back-link {
    text-align: center;
    margin-top: 2rem;
  }
</style>
